#!/usr/bin/env sh
set -eu

APP_ID="dev.pinleaf.Pinleaf"
APP_NAME="Pinleaf"

fail() {
  printf '%s\n' "install-local: $*" >&2
  exit 1
}

repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$repo_root"

[ -f "pyproject.toml" ] || fail "run from the Pinleaf repository root"
[ -d "pinleaf" ] || fail "run from the Pinleaf repository root"
[ -f "pinleaf/resources/icons/pinleaf.png" ] || fail "missing Pinleaf icon resources"

bin_dir="${HOME}/.local/bin"
apps_dir="${HOME}/.local/share/applications"
icons_root="${HOME}/.local/share/icons/hicolor"

mkdir -p "$bin_dir" "$apps_dir"
mkdir -p \
  "$icons_root/16x16/apps" \
  "$icons_root/32x32/apps" \
  "$icons_root/64x64/apps" \
  "$icons_root/256x256/apps" \
  "$icons_root/scalable/apps"

wrapper="${bin_dir}/pinleaf"
desktop_file="${apps_dir}/${APP_ID}.desktop"

cat > "$wrapper" <<EOF
#!/usr/bin/env sh
cd "$repo_root"
exec /usr/bin/python3 -m pinleaf "\$@"
EOF
chmod 0755 "$wrapper"

cp "pinleaf/resources/icons/pinleaf-16.png" "$icons_root/16x16/apps/pinleaf.png"
cp "pinleaf/resources/icons/pinleaf-32.png" "$icons_root/32x32/apps/pinleaf.png"
cp "pinleaf/resources/icons/pinleaf-64.png" "$icons_root/64x64/apps/pinleaf.png"
cp "pinleaf/resources/icons/pinleaf.png" "$icons_root/256x256/apps/pinleaf.png"
cp "pinleaf/resources/icons/pinleaf.svg" "$icons_root/scalable/apps/pinleaf.svg"

cat > "$desktop_file" <<EOF
[Desktop Entry]
Type=Application
Name=${APP_NAME}
Comment=Desktop sticky notes
Exec=${wrapper}
Icon=pinleaf
Terminal=false
Categories=Utility;Office;
StartupWMClass=${APP_ID}
EOF
chmod 0644 "$desktop_file"

if command -v update-desktop-database >/dev/null 2>&1; then
  update-desktop-database "$apps_dir" >/dev/null 2>&1 || true
fi

if command -v gtk-update-icon-cache >/dev/null 2>&1; then
  gtk-update-icon-cache "$icons_root" >/dev/null 2>&1 || true
fi

printf '%s\n' "Installed Pinleaf local launcher:"
printf '  %s\n' "$wrapper"
printf '  %s\n' "$desktop_file"
printf '  %s\n' "$icons_root"
